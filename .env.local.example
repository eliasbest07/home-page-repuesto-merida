# ─── Plaza AI Assistant ───────────────────────────────────────────────
# Copia este archivo como .env.local y rellena tus valores reales.
# NUNCA subas .env.local a git.

# API Key de Anthropic para el asistente Plaza AI
# Obtén la tuya en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXX

# ─── Opcional: URL base del sitio ─────────────────────────────────────
# NEXT_PUBLIC_SITE_URL=https://repuestosmerida.com

# ─── WhatsApp cifrado (solo servidor) ────────────────────────────────
# URL privada que recibe el JSON cifrado. No uses prefijo NEXT_PUBLIC_.
WA_BOT_SEND_URL=https://tu-servidor-whatsapp.example/api/wa/send

# Opcional: autenticación adicional entre servidores.
WA_BOT_AUTH=Bearer CAMBIA_ESTE_TOKEN

# Misma llave en esta aplicación y en el servidor receptor.
# Usa una cadena aleatoria de al menos 32 caracteres.
WA_ENCRYPTION_MASTER_KEY=CAMBIA_POR_UN_SECRETO_ALEATORIO_DE_64_CARACTERES

# Firma las credenciales efímeras entregadas a cada navegador.
WA_CLIENT_KEY_SECRET=CAMBIA_POR_OTRO_SECRETO_ALEATORIO_DE_64_CARACTERES

# Protege los códigos guardados en la base de datos mediante HMAC.
WA_OTP_HASH_SECRET=CAMBIA_POR_OTRO_SECRETO_ALEATORIO_DE_64_CARACTERES
