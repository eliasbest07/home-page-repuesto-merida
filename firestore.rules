rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Anuncios: lectura pública para el feed
    // Escritura: cualquiera que envíe los campos requeridos (auth por OTP/WhatsApp en cliente)
    // Actualizar: solo si el telefono coincide
    match /anuncios/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['titulo', 'tipo', 'telefono'])
                    && request.resource.data.titulo is string
                    && request.resource.data.titulo.size() > 0;
      allow update: if request.resource.data.telefono == resource.data.telefono
                    || request.auth != null;
      allow delete: if request.auth != null;
    }

    // ── Bingo ─────────────────────────────────────────────────────────────────
    match /bingo_salas/{salaId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['codigo', 'host_session', 'estado'])
                    && request.resource.data.codigo is string
                    && request.resource.data.codigo.size() == 6;
      allow update: if true;  // MVP: sin auth, control en cliente

      match /jugadores/{jugadorId} {
        allow read: if true;
        allow create: if request.resource.data.keys().hasAll(['nombre', 'session_id', 'carton'])
                      && request.resource.data.nombre is string
                      && request.resource.data.nombre.size() > 0;
        allow update: if true;
        allow delete: if false;
      }
    }

    // Catálogo público de repuestos para la home.
    match /merida/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Comentarios públicos en la lista de repuestos solicitados.
    match /solicitudes_comentarios/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly([
                      'solicitud_id',
                      'autor',
                      'texto',
                      'whatsapp',
                      'creado_en'
                    ])
                    && request.resource.data.solicitud_id is int
                    && request.resource.data.autor is string
                    && request.resource.data.autor.size() > 0
                    && request.resource.data.autor.size() <= 50
                    && request.resource.data.texto is string
                    && request.resource.data.texto.size() > 0
                    && request.resource.data.texto.size() <= 500
                    && request.resource.data.whatsapp is string
                    && request.resource.data.whatsapp.size() <= 18
                    && request.resource.data.creado_en == request.time;
      allow update, delete: if false;
    }

    // Solicitudes creadas desde la portada.
    match /solicitudes_repuestos/{id} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly([
                      'id',
                      'contacto_id',
                      'repuesto',
                      'tipo_vehiculo',
                      'marca',
                      'modelo',
                      'anio',
                      'cantidad',
                      'estado',
                      'confianza',
                      'falta_info',
                      'destacada',
                      'notas',
                      'creado_en',
                      'title',
                      'numero'
                    ])
                    && request.resource.data.id is int
                    && request.resource.data.repuesto is string
                    && request.resource.data.repuesto.size() > 0
                    && request.resource.data.repuesto.size() <= 120
                    && request.resource.data.tipo_vehiculo in ['carro', 'moto', 'bicicleta']
                    && request.resource.data.marca is string
                    && request.resource.data.marca.size() > 0
                    && request.resource.data.modelo is string
                    && request.resource.data.modelo.size() > 0
                    && request.resource.data.modelo.size() <= 80
                    && request.resource.data.anio is string
                    && request.resource.data.anio.size() == 4
                    && request.resource.data.numero is string
                    && request.resource.data.numero.size() >= 10
                    && request.resource.data.numero.size() <= 18
                    && request.resource.data.estado == 'solicitado'
                    && request.resource.data.destacada == false
                    && request.resource.data.creado_en == request.time;
      allow update, delete: if false;
    }

    // Enlaces mágicos de login: SOLO el bot (admin SDK) los crea/borra. La web
    // los lee por su token (id secreto de 256 bits, sin 'list') y solo puede
    // marcarlos como usados. No se puede enumerar ni crear desde el cliente.
    match /magic_links/{token} {
      allow get: if true;
      allow list, create, delete: if false;
      allow update: if request.resource.data.usado == true
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['usado', 'usado_en']);
    }

    // Imágenes y datos de verificación — solo admin
    match /usuarios_plaza/{telefono} {
      allow read, write: if request.auth != null;
    }
  }
}
